# Copy this file to .env and replace every placeholder with a unique secret.
# Never commit the resulting .env file.
MYSQL_ROOT_PASSWORD=replace-with-a-long-random-password
DB_USERNAME=supervision
DB_PASSWORD=replace-with-a-different-long-random-password
RABBITMQ_USERNAME=supervision
RABBITMQ_PASSWORD=replace-with-another-long-random-password
# Generate with: openssl rand -base64 32
SUPERVISION_CRYPTO_KEY=replace-with-a-32-byte-random-key
SUPERVISION_ADMIN_USERNAME=admin
SUPERVISION_ADMIN_PASSWORD=replace-with-a-strong-initial-password
